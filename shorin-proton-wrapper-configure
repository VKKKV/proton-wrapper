            self.res_combo.append(value, label)
        initial_res = (initial or {}).get("gamescope_res", "")
        res_options = resolution_options()
        if initial_res and initial_res not in res_options:
            self.res_combo.set_active_id("custom")
        else:
            self.res_combo.set_active_id(initial_res or "unset")
        self.res_combo.connect("changed", self.on_display_option_changed)
        self.custom_res_entry = Gtk.Entry(placeholder_text=TEXT["custom_resolution"], hexpand=True)
        if initial_res:
            self.custom_res_entry.set_text(initial_res)
        self.custom_res_entry.set_visible(False)
        res_box.append(res_label)
        res_box.append(self.res_combo)
        res_box.append(self.custom_res_entry)
        gamescope_box.attach(res_box, 1, 0, 1, 1)

        fps_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        fps_label = Gtk.Label(label=TEXT["fps"], xalign=0)
        fps_label.set_size_request(88, -1)
        self.fps_combo = Gtk.ComboBoxText()
        self.fps_combo.set_hexpand(True)
        for value in fps_options():
            label = TEXT["unlimited"] if value == "unset" else TEXT["custom"] if value == "custom" else value
            self.fps_combo.append(value, label)
        initial_fps = (initial or {}).get("gamescope_fps", "")
        fps_values = fps_options()
        if initial_fps and initial_fps not in fps_values:
            self.fps_combo.set_active_id("custom")
        else:
            self.fps_combo.set_active_id(initial_fps or "unset")
        self.fps_combo.connect("changed", self.on_display_option_changed)
        self.custom_fps_entry = Gtk.Entry(placeholder_text=TEXT["custom_fps"], hexpand=True)
        if initial_fps:
            self.custom_fps_entry.set_text(initial_fps)
        self.custom_fps_entry.set_visible(False)
        fps_box.append(fps_label)
        fps_box.append(self.fps_combo)
        fps_box.append(self.custom_fps_entry)
        gamescope_box.attach(fps_box, 1, 1, 1, 1)

        self.fsr_check = Gtk.CheckButton(label=TEXT["fsr"])
        self.fsr_check.set_active((initial or {}).get("gamescope_fsr", "0") == "1")
        gamescope_box.attach(self.fsr_check, 0, 2, 2, 1)

        extra_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        extra_label = Gtk.Label(label=TEXT["extra_args"], xalign=0)
        extra_label.set_size_request(88, -1)
        self.extra_args_entry = Gtk.Entry(placeholder_text="--mangoapp --force-grab-cursor", hexpand=True)
        self.extra_args_entry.set_text((initial or {}).get("gamescope_args", ""))
        extra_box.append(extra_label)
        extra_box.append(self.extra_args_entry)
        gamescope_box.attach(extra_box, 0, 3, 2, 1)
        extra_desc = Gtk.Label(label=TEXT["extra_args_desc"], xalign=0, wrap=True)
        extra_desc.add_css_class("dim-label")
        gamescope_box.attach(extra_desc, 0, 4, 2, 1)
        gamescope_card.append(gamescope_box)
        outer.append(gamescope_card)

        display_card = card(TEXT["display"])
        display_box = Gtk.Grid(column_spacing=16, row_spacing=8)
        display_box.set_hexpand(True)
        self.mangohud_check = Gtk.CheckButton(label=TEXT["mangohud"])
        self.mangohud_check.set_active(self.mangohud_available and (initial or {}).get("mangohud", "0") == "1")
        self.mangohud_check.set_sensitive(self.mangohud_available)
        display_box.attach(self.mangohud_check, 0, 0, 2, 1)
        mangohud_desc = Gtk.Label(label=TEXT["mangohud_desc"], xalign=0, wrap=True)
        mangohud_desc.add_css_class("dim-label")
        display_box.attach(mangohud_desc, 0, 1, 2, 1)
        next_row = 2
        if not self.mangohud_available:
            self.mangohud_missing_label = Gtk.Label(label=TEXT["mangohud_missing"], xalign=0, wrap=True)
            self.mangohud_missing_label.add_css_class("dim-label")
            display_box.attach(self.mangohud_missing_label, 0, 2, 2, 1)
            next_row = 3

        env_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        env_label = Gtk.Label(label=TEXT["env_vars"], xalign=0)
        env_label.set_size_request(88, -1)
        self.env_vars_entry = Gtk.Entry(placeholder_text="DXVK_ASYNC=1 PROTON_NO_ESYNC=1", hexpand=True)
        self.env_vars_entry.set_text((initial or {}).get("env_vars", ""))
        env_box.append(env_label)
        env_box.append(self.env_vars_entry)
        display_box.attach(env_box, 0, next_row, 2, 1)
        env_desc = Gtk.Label(label=TEXT["env_vars_desc"], xalign=0, wrap=True)
        env_desc.add_css_class("dim-label")
        display_box.attach(env_desc, 0, next_row + 1, 2, 1)
        display_card.append(display_box)
        outer.append(display_card)
        self.on_gamescope_toggled(self.gamescope_check)

        buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        buttons.set_halign(Gtk.Align.END)
        cancel = Gtk.Button(label=TEXT["cancel"])
        run = Gtk.Button(label=TEXT["run"])
        cancel.connect("clicked", lambda _b: self.quit())
        run.connect("clicked", self.on_run)
        buttons.append(cancel)
        buttons.append(run)
        outer.append(buttons)

        self.window.set_child(outer)
        self.window.present()
        if not self.runners:
            self.show_error(TEXT["no_runner"])

    def on_runner_changed(self, combo):
        active_id = combo.get_active_id()
        if active_id is None:
            self.selected_runner = None
            self.update_runner_detail()
            return
        index = int(active_id)
        if 0 <= index < len(self.runners):
            self.selected_runner = self.runners[index]["path"]
        self.update_runner_detail()

    def update_runner_detail(self):
        if not self.runner_detail:
            return
        active_id = self.runner_combo.get_active_id() if self.runner_combo else None
        if active_id is None:
            self.runner_detail.set_text("")
            return
        index = int(active_id)
        if 0 <= index < len(self.runners):
            runner = self.runners[index]
            self.runner_detail.set_text(f'{runner["type"]} · {runner["source"]}\n{runner["path"]}')
        else:
            self.runner_detail.set_text("")

    def on_browse(self, _button):
        dialog = Gtk.FileChooserNative(
            title=TEXT["prefix"],
            transient_for=self.window,
            action=Gtk.FileChooserAction.SELECT_FOLDER,
            accept_label=TEXT["browse"],
            cancel_label=TEXT["cancel"],
        )
        dialog.connect("response", self.on_folder_response)
        dialog.show()

    def on_browse_exe(self, _button):
        dialog = Gtk.FileChooserNative(
            title=TEXT["program"],
            transient_for=self.window,
            action=Gtk.FileChooserAction.OPEN,
            accept_label=TEXT["browse"],
            cancel_label=TEXT["cancel"],
        )
        dialog.connect("response", self.on_exe_response)
        dialog.show()

    def on_exe_response(self, dialog, response):
        if response == Gtk.ResponseType.ACCEPT:
            file = dialog.get_file()
            if file:
                path = file.get_path()
                if path and self.exe_entry:
                    self.exe_entry.set_text(path)
        dialog.destroy()

    def on_folder_response(self, dialog, response):
        if response == Gtk.ResponseType.ACCEPT:
            with warnings.catch_warnings():
                warnings.simplefilter("ignore", DeprecationWarning)
                file = dialog.get_file()
            if file:
                path = file.get_path()
                if path:
                    self.prefix_entry.set_text(path)
        dialog.destroy()

    def on_gamescope_toggled(self, button):
        active = button.get_active()
        for widget in (self.fullscreen_check, self.res_combo, self.custom_res_entry, self.fps_combo, self.custom_fps_entry, self.fsr_check, self.extra_args_entry):
            if widget:
                widget.set_sensitive(active)
        self.on_display_option_changed(None)

    def on_display_option_changed(self, _widget):
        if self.custom_res_entry and self.res_combo:
            self.custom_res_entry.set_visible(self.res_combo.get_active_id() == "custom")
        if self.custom_fps_entry and self.fps_combo:
            self.custom_fps_entry.set_visible(self.fps_combo.get_active_id() == "custom")

    def selected_gamescope_options(self):
        enabled = self.gamescope_check.get_active() if self.gamescope_check else False
        res = self.res_combo.get_active_id() if self.res_combo else ""
        fps = self.fps_combo.get_active_id() if self.fps_combo else ""
        if res == "unset":
            res = ""
        if fps == "unset":
            fps = ""
        if res == "custom":
            res = self.custom_res_entry.get_text().strip()
            if not is_resolution(res):
                self.show_error(TEXT["invalid_resolution"])
                return None
        if fps == "custom":
            fps = self.custom_fps_entry.get_text().strip()
            if not is_number(fps):
                self.show_error(TEXT["invalid_fps"])
                return None
        return {
            "gamescope": "1" if enabled else "0",
            "gamescope_fullscreen": "1" if self.fullscreen_check and self.fullscreen_check.get_active() else "0",
            "gamescope_res": res or "",
            "gamescope_fps": fps or "",
            "gamescope_fsr": "1" if self.fsr_check and self.fsr_check.get_active() else "0",
            "gamescope_args": self.extra_args_entry.get_text().strip() if self.extra_args_entry else "",
            "mangohud": "1" if self.mangohud_check and self.mangohud_check.get_active() else "0",
            "env_vars": self.env_vars_entry.get_text().strip() if self.env_vars_entry else "",
        }

    def on_run(self, _button):
        old_cache_file = self.cache_file
        if self.exe_entry:
            self.exe = normalize_exe_arg(self.exe_entry.get_text())
            self.cache_file = cache_file_for(self.exe)
        prefix = self.prefix_entry.get_text()
        if not prefix:
            self.show_error(TEXT["select_prefix"])
            return
        if not self.selected_runner:
            self.show_error(TEXT["select_runner"])
            return
        options = self.selected_gamescope_options()
        if options is None:
            return
        write_cache(self.cache_file, self.exe, prefix, self.selected_runner, options)
        if old_cache_file != self.cache_file:
            old_cache_file.unlink(missing_ok=True)
        self.run_with(prefix, self.selected_runner, options)


def main():
    if len(sys.argv) < 2:
        print(TEXT["no_exe_error"], file=sys.stderr)
        return 1
    exe = normalize_exe_arg(sys.argv[1])
    app = SelectorApp(exe)
    try:
        return app.run([sys.argv[0]])
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
