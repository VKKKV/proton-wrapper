def runner_label(runner: dict) -> str:
    detail = runner.get("source") or runner.get("type")
    return f'{runner["name"]} · {detail}' if detail else runner["name"]


def prefer_dark_theme() -> bool:
    try:
        result = subprocess.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
            check=False,
            text=True,
            capture_output=True,
        )
    except OSError:
        return False
    return "prefer-dark" in result.stdout


def sync_color_scheme():
    settings = Gtk.Settings.get_default()
    if settings:
        settings.set_property("gtk-application-prefer-dark-theme", prefer_dark_theme())


