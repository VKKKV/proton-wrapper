die() {
  printf 'shorin-proton-wrapper: %s\n' "$*" >&2
  exit 1
}

die_runner_not_found() {
  local runner="$1"
  if [[ "$(ui_lang)" == "zh" ]]; then
    die "未找到或不支持的运行器: $runner
使用 --list-runner 查看可用运行器，或使用 --runner ge/dw。"
  else
    die "runner not found or unsupported: $runner
Use --list-runner to see available runners, or use --runner ge/dw."
  fi
}

expand_path() {
  local path="$1"
  case "$path" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s\n' "$HOME/${path#~/}" ;;
    *) realpath -m "$path" ;;
  esac
}

xdg_download_dir() {
  local value line config
  if command -v xdg-user-dir >/dev/null 2>&1; then
    value="$(xdg-user-dir DOWNLOAD 2>/dev/null || true)"
    if [[ -n "$value" ]]; then
      expand_path "$value"
      return 0
    fi
  fi

  config="${XDG_CONFIG_HOME:-$HOME/.config}/user-dirs.dirs"
  if [[ -r "$config" ]]; then
    while IFS= read -r line; do
      if [[ "$line" =~ ^XDG_DOWNLOAD_DIR=\"(.*)\"$ ]]; then
        value="${BASH_REMATCH[1]}"
        value="${value//\$HOME/$HOME}"
        expand_path "$value"
        return 0
      fi
    done < "$config"
  fi

  printf '%s\n' "$HOME/Downloads"
}

steam_root_dir() {
  if [[ -d "$STEAM_ROOT" ]]; then
    expand_path "$STEAM_ROOT"
  elif [[ -d "$HOME/.local/share/Steam" ]]; then
    printf '%s\n' "$HOME/.local/share/Steam"
  else
    expand_path "$STEAM_ROOT"
  fi
}

default_install_dir() {
  case "$INSTALL_TO" in
    local)
      printf '%s\n' "$LOCAL_RUNNER_DIR"
      ;;
    steam)
      printf '%s\n' "$HOME/.local/share/Steam/compatibilitytools.d"
      ;;
    lutris)
      printf '%s\n' "$HOME/.local/share/lutris/runners/wine"
      ;;
    *)
      die "unknown install target: $INSTALL_TO"
      ;;
  esac
}

runner_name_from_path() {
  local type="$1" path="$2" root
  if [[ "$type" == "proton" ]]; then
    basename "$(dirname "$path")"
    return 0
  fi

  root="$(dirname "$path")"
  if [[ "$(basename "$root")" == "bin" ]]; then
    root="$(dirname "$root")"
  fi
  if [[ "$(basename "$root")" == "files" ]]; then
    root="$(dirname "$root")"
  fi
  basename "$root"
}

wine_root_has_proton() {
  local path="$1" root
  root="$(dirname "$path")"
  if [[ "$(basename "$root")" == "bin" ]]; then
    root="$(dirname "$root")"
  fi
  if [[ "$(basename "$root")" == "files" ]]; then
    root="$(dirname "$root")"
  fi
  [[ -x "$root/proton" ]]
}

reset_runners() {
  RUNNER_TYPES=()
  RUNNER_SOURCES=()
  RUNNER_NAMES=()
  RUNNER_PATHS=()
  RUNNER_SEEN=()
}

add_runner() {
  local type="$1" source="$2" path="$3" name real
  [[ -x "$path" ]] || return 0

  real="$(realpath -m "$path")"
  [[ -n "${RUNNER_SEEN[$real]:-}" ]] && return 0
  RUNNER_SEEN["$real"]=1

  name="$(runner_name_from_path "$type" "$path")"
  RUNNER_TYPES+=("$type")
  RUNNER_SOURCES+=("$source")
  RUNNER_NAMES+=("$name")
  RUNNER_PATHS+=("$real")
}

add_proton_paths() {
  local source="$1" path
  shift || true
  for path in "$@"; do
    add_runner proton "$source" "$path"
  done
}

add_wine_paths() {
  local source="$1" path
  shift || true
  for path in "$@"; do
    if ! wine_root_has_proton "$path"; then
      add_runner wine "$source" "$path"
    fi
  done
}

read_steam_libraries() {
  local file line lib
  for file in \
    "$HOME/.local/share/Steam/steamapps/libraryfolders.vdf" \
    "$HOME/.steam/root/steamapps/libraryfolders.vdf"; do
    [[ -r "$file" ]] || continue
    while IFS= read -r line; do
      if [[ "$line" =~ \"path\"[[:space:]]+\"([^\"]+)\" ]]; then
        lib="${BASH_REMATCH[1]}"
        expand_path "$lib"
      fi
    done < "$file"
  done
}

collect_runners() {
  local lib
  reset_runners

  if [[ -n "${PROTON_RUNNER:-}" ]]; then
    try_resolve_runner_arg "$PROTON_RUNNER" >/dev/null 2>&1 || true
    if [[ -n "${RESOLVED_RUNNER_PATH:-}" ]]; then
      add_runner "$RESOLVED_RUNNER_TYPE" env "$RESOLVED_RUNNER_PATH"
    fi
  fi

  if [[ -n "${PROTON_GE_PATH:-}" ]]; then
    try_resolve_runner_arg "$PROTON_GE_PATH" >/dev/null 2>&1 || true
    if [[ -n "${RESOLVED_RUNNER_PATH:-}" ]]; then
      add_runner "$RESOLVED_RUNNER_TYPE" env "$RESOLVED_RUNNER_PATH"
    fi
  fi

  shopt -s nullglob
  add_proton_paths local "$LOCAL_RUNNER_DIR"/*/proton

  add_proton_paths steam-compat \
    "$HOME/.local/share/Steam/compatibilitytools.d/DW-Proton Latest/proton" \
    "$HOME/.steam/root/compatibilitytools.d/DW-Proton Latest/proton" \
    "$HOME/.local/share/Steam/compatibilitytools.d/Proton-GE Latest/proton" \
    "$HOME/.steam/root/compatibilitytools.d/Proton-GE Latest/proton"
  add_proton_paths steam-compat \
    "$HOME/.local/share/Steam/compatibilitytools.d"/*/proton \
    "$HOME/.steam/root/compatibilitytools.d"/*/proton

  add_proton_paths lutris \
    "$HOME/.local/share/lutris/runners/proton"/*/proton \
    "$HOME/.local/share/lutris/runners/wine"/*/proton \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/proton"/*/proton \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/wine"/*/proton

  add_proton_paths steam-official \
    "$HOME/.local/share/Steam/steamapps/common/Proton - Experimental/proton" \
    "$HOME/.steam/root/steamapps/common/Proton - Experimental/proton"
  add_proton_paths steam-official \
    "$HOME/.local/share/Steam/steamapps/common"/Proton*/proton \
    "$HOME/.steam/root/steamapps/common"/Proton*/proton

  while IFS= read -r lib; do
    [[ -n "$lib" ]] || continue
    add_proton_paths steam-library "$lib/steamapps/common"/Proton*/proton
  done < <(read_steam_libraries)

  add_wine_paths lutris-wine \
    "$HOME/.local/share/lutris/runners/wine"/*/files/bin/wine \
    "$HOME/.local/share/lutris/runners/wine"/*/bin/wine \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/wine"/*/files/bin/wine \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/wine"/*/bin/wine
  shopt -u nullglob
}

RESOLVED_RUNNER_TYPE=""
RESOLVED_RUNNER_PATH=""

try_resolve_runner_arg() {
  local input path base root product
  input="$1"
  RESOLVED_RUNNER_TYPE=""
  RESOLVED_RUNNER_PATH=""

  if product="$(runner_product_alias "$input")"; then
    try_resolve_runner_product "$product"
    return $?
  fi

  path="$(expand_path "$input")"

  if [[ -d "$path" && -x "$path/proton" ]]; then
    RESOLVED_RUNNER_TYPE="proton"
    RESOLVED_RUNNER_PATH="$(realpath -m "$path/proton")"
    return 0
  fi

  if [[ -f "$path" && -x "$path" ]]; then
    base="$(basename "$path")"
    if [[ "$base" == "proton" ]]; then
      RESOLVED_RUNNER_TYPE="proton"
      RESOLVED_RUNNER_PATH="$(realpath -m "$path")"
      return 0
    fi
    if [[ "$base" == "wine" || "$base" == "wine64" ]]; then
      RESOLVED_RUNNER_TYPE="wine"
      RESOLVED_RUNNER_PATH="$(realpath -m "$path")"
      return 0
    fi
  fi

  if [[ -d "$path" ]]; then
    for root in "$path/files/bin/wine" "$path/bin/wine"; do
      if [[ -x "$root" ]]; then
        RESOLVED_RUNNER_TYPE="wine"
        RESOLVED_RUNNER_PATH="$(realpath -m "$root")"
        return 0
      fi
    done
  fi

  return 1
}

try_resolve_runner_from_prefix() {
  local config_line runner_root
  RESOLVED_RUNNER_TYPE=""
  RESOLVED_RUNNER_PATH=""

  [[ -r "$PREFIX/config_info" ]] || return 1
  config_line="$(sed -n '2p' "$PREFIX/config_info")"
  [[ -n "$config_line" ]] || return 1

  runner_root="$(dirname "$(dirname "$(dirname "$config_line")")")"
  if [[ -x "$runner_root/proton" ]]; then
    RESOLVED_RUNNER_TYPE="proton"
    RESOLVED_RUNNER_PATH="$(realpath -m "$runner_root/proton")"
    return 0
  fi
  if [[ -x "$runner_root/bin/wine" ]]; then
    RESOLVED_RUNNER_TYPE="wine"
    RESOLVED_RUNNER_PATH="$(realpath -m "$runner_root/bin/wine")"
    return 0
  fi

  return 1
}

resolve_runner_arg() {
  try_resolve_runner_arg "$1" || die_runner_not_found "$1"
}

try_select_runner() {
  if [[ -n "$RUNNER_ARG" ]]; then
    try_resolve_runner_arg "$RUNNER_ARG"
    return $?
  fi

  if try_resolve_runner_from_prefix; then
    return 0
  fi

  collect_runners
  if [[ ${#RUNNER_PATHS[@]} -eq 0 ]]; then
    return 1
  fi

  RESOLVED_RUNNER_TYPE="${RUNNER_TYPES[0]}"
  RESOLVED_RUNNER_PATH="${RUNNER_PATHS[0]}"
  return 0
}

select_runner() {
  if try_select_runner; then
    return 0
  fi

  if [[ -n "$RUNNER_ARG" ]]; then
    die_runner_not_found "$RUNNER_ARG"
  fi

  ensure_runner_product dw || die "failed to install runner: dw"
}

list_runners() {
  local selected_path mark i
  collect_runners

  selected_path=""
  if [[ -n "$RUNNER_ARG" ]]; then
    resolve_runner_arg "$RUNNER_ARG"
    selected_path="$(realpath -m "$RESOLVED_RUNNER_PATH")"
  elif [[ ${#RUNNER_PATHS[@]} -gt 0 ]]; then
    selected_path="${RUNNER_PATHS[0]}"
  fi

  if [[ ${#RUNNER_PATHS[@]} -eq 0 ]]; then
    printf 'No runners found.\n'
    return 0
  fi

  for i in "${!RUNNER_PATHS[@]}"; do
    if [[ "${RUNNER_PATHS[$i]}" == "$selected_path" ]]; then
      printf '  * %s\n' "${RUNNER_NAMES[$i]}"
    else
      printf '    %s\n' "${RUNNER_NAMES[$i]}"
    fi
    printf '      type:   %s\n' "${RUNNER_TYPES[$i]}"
    printf '      source: %s\n' "${RUNNER_SOURCES[$i]}"
    printf '      path:   %s\n' "${RUNNER_PATHS[$i]}"
  done
}

normalize_product() {
  local product="${1,,}"
  case "$product" in
    ge|ge-proton|proton-ge)
      printf 'ge\n'
      ;;
    dw|dwproton|dw-proton|dw_proton)
      printf 'dw\n'
      ;;
    *)
      die "unknown runner product: $1"
      ;;
  esac
}

runner_dir_name() {
  local product="$1"
  case "$product" in
    ge) printf 'Proton-GE Latest' ;;
    dw) printf 'DW-Proton Latest' ;;
    *) die "unknown runner product: $product" ;;
  esac
}

runner_target_dir_name() {
  local product="$1" version="$2" tag="${3:-}"
  if [[ "$version" == "latest" ]]; then
    runner_dir_name "$product"
  else
    printf '%s\n' "${tag:-$version}"
  fi
}

runner_product_alias() {
  local product="${1,,}"
  case "$product" in
    ge|ge-proton|proton-ge)
      printf 'ge\n'
      ;;
    dw|dwproton|dw-proton|dw_proton)
      printf 'dw\n'
      ;;
    *)
      return 1
      ;;
  esac
}

try_resolve_runner_product() {
  local product="$1" name path
  name="$(runner_dir_name "$product")"

  for path in \
    "$LOCAL_RUNNER_DIR/$name/proton" \
    "$HOME/.local/share/Steam/compatibilitytools.d/$name/proton" \
    "$HOME/.steam/root/compatibilitytools.d/$name/proton" \
    "$HOME/.local/share/lutris/runners/proton/$name/proton" \
    "$HOME/.local/share/lutris/runners/wine/$name/proton" \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/proton/$name/proton" \
    "$HOME/.var/app/net.lutris.Lutris/data/lutris/runners/wine/$name/proton"; do
    if [[ -x "$path" ]]; then
      RESOLVED_RUNNER_TYPE="proton"
      RESOLVED_RUNNER_PATH="$(realpath -m "$path")"
      return 0
    fi
  done

  return 1
}

list_versions() {
  local product="$1"
  product="$(normalize_product "$product")"
  python3 - "$product" <<'PY'
import json
import sys
import urllib.request
import urllib.error

product = sys.argv[1]

if product == "ge":
    url = "https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases?per_page=20"
elif product == "dw":
    url = "https://dawn.wine/api/v1/repos/dawn-winery/dwproton/releases?limit=20"
else:
    raise SystemExit(f"unknown product: {product}")

request = urllib.request.Request(url, headers={"User-Agent": "proton-cli"})
try:
    with urllib.request.urlopen(request, timeout=30) as response:
        data = json.load(response)
except urllib.error.HTTPError as exc:
    raise SystemExit(f"failed to fetch version list: HTTP {exc.code}")
except urllib.error.URLError as exc:
    raise SystemExit(f"failed to fetch version list: {exc.reason}")

if isinstance(data, dict):
    data = [data]

for release in data:
    tag = release.get("tag_name") or release.get("name") or ""
    if not tag:
        continue
    published = release.get("published_at") or release.get("created_at") or ""
    published = published[:10]
    print(f"{tag}  {published}")
PY
}

release_info() {
  local product="$1" version="$2"
  python3 - "$product" "$version" <<'PY'
import json
import sys
import urllib.request
import urllib.error

product = sys.argv[1]
version = sys.argv[2]

if product == "ge":
    if version == "latest":
        url = "https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest"
    else:
        url = f"https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/tags/{version}"
    archive_suffixes = (".tar.gz",)
    checksum_suffix = ".sha512sum"
elif product == "dw":
    if version == "latest":
        url = "https://dawn.wine/api/v1/repos/dawn-winery/dwproton/releases/latest"
    else:
        url = f"https://dawn.wine/api/v1/repos/dawn-winery/dwproton/releases/tags/{version}"
    archive_suffixes = ("x86_64.tar.xz",)
    checksum_suffix = "x86_64.sha512sum"
else:
    raise SystemExit(f"unknown product: {product}")

request = urllib.request.Request(url, headers={"User-Agent": "proton-cli"})
try:
    with urllib.request.urlopen(request, timeout=30) as response:
        data = json.load(response)
except urllib.error.HTTPError as exc:
    raise SystemExit(f"release not found for {product} {version}: HTTP {exc.code}")
except urllib.error.URLError as exc:
    raise SystemExit(f"failed to fetch release info for {product} {version}: {exc.reason}")

assets = data.get("assets") or []
tag = data.get("tag_name") or data.get("name") or version
archive = None
checksum = None

for asset in assets:
    name = asset.get("name", "")
    download = asset.get("browser_download_url", "")
    if not download:
        continue
    if archive is None and any(name.endswith(suffix) for suffix in archive_suffixes):
        archive = (name, download)
    if checksum is None and name.endswith(checksum_suffix):
        checksum = (name, download)

if archive is None:
    raise SystemExit(f"archive asset not found for {product} {version}")
if checksum is None:
    raise SystemExit(f"checksum asset not found for {product} {version}")

print(tag)
print(archive[0])
print(archive[1])
print(checksum[0])
print(checksum[1])
PY
}

fetch_file() {
  local url="$1" dest="$2" tmp
  if [[ -s "$dest" ]]; then
    printf 'Using existing: %s\n' "$dest"
    return 0
  fi

  tmp="$dest.part"
  rm -f "$tmp"
  if command -v curl >/dev/null 2>&1; then
    if ! curl -L --fail --progress-bar -o "$tmp" "$url"; then
      rm -f "$tmp"
      printf 'shorin-proton-wrapper: download failed: %s -> %s\n' "$url" "$dest" >&2
      return 1
    fi
  elif command -v wget >/dev/null 2>&1; then
    if ! wget -O "$tmp" "$url"; then
      rm -f "$tmp"
      printf 'shorin-proton-wrapper: download failed: %s -> %s\n' "$url" "$dest" >&2
      return 1
    fi
  else
    die "curl or wget is required for downloads"
  fi
  mv "$tmp" "$dest"
}

verify_archive() {
  local dir="$1" checksum_name="$2"
  if ! (cd "$dir" && sha512sum -c "$checksum_name"); then
    printf 'shorin-proton-wrapper: checksum verification failed: %s/%s\n' "$dir" "$checksum_name" >&2
    printf 'shorin-proton-wrapper: the downloaded archive may be corrupted. Delete the archive and checksum file, then retry.\n' >&2
    return 1
  fi
}

find_extracted_runner_root() {
  local extract_dir="$1" path
  if [[ -x "$extract_dir/proton" ]]; then
    printf '%s\n' "$extract_dir"
    return 0
  fi

  shopt -s nullglob
  for path in "$extract_dir"/*; do
    if [[ -d "$path" && -x "$path/proton" ]]; then
      shopt -u nullglob
      printf '%s\n' "$path"
      return 0
    fi
  done
  shopt -u nullglob

  return 1
}

installed_runner_version() {
  local target="$1" product="$2" line version

  if [[ -r "$target/.shorin-proton-wrapper-version" ]]; then
    sed -n '1p' "$target/.shorin-proton-wrapper-version"
    return 0
  fi

  if [[ -r "$target/version" ]]; then
    line="$(sed -n '1p' "$target/version")"
    case "$product" in
      ge)
        version="$(printf '%s\n' "$line" | grep -o 'GE-Proton[^[:space:]]*' | head -n 1 || true)"
        ;;
      dw)
        version="$(printf '%s\n' "$line" | grep -o 'dwproton-[^[:space:]]*' | head -n 1 || true)"
        ;;
      *)
        version=""
        ;;
    esac
    [[ -n "$version" ]] && printf '%s\n' "$version"
  fi
}

download_runner() {
  local product info tag archive_name archive_url checksum_name checksum_url dir release_output
  product="$(normalize_product "$PRODUCT")"
  info=()
  release_output="$(release_info "$product" "$VERSION" 2>&1)" || die "$release_output"
  mapfile -t info <<< "$release_output"
  tag="${info[0]:-}" archive_name="${info[1]:-}" archive_url="${info[2]:-}" checksum_name="${info[3]:-}" checksum_url="${info[4]:-}"
  [[ -n "$tag" ]] || die "release not found for $product $VERSION"
  dir="$(expand_path "${DOWNLOAD_DIR:-$(xdg_download_dir)}")"

  mkdir -p "$dir"
  fetch_file "$archive_url" "$dir/$archive_name" || exit 1
  fetch_file "$checksum_url" "$dir/$checksum_name" || exit 1
  verify_archive "$dir" "$checksum_name" || exit 1

  printf 'Downloaded: %s\n' "$dir/$archive_name"
  printf 'Checksum:   %s\n' "$dir/$checksum_name"
  printf 'Verified:   yes\n'
  printf 'Version:    %s\n' "$tag"
}

install_runner() {
  local product info tag archive_name archive_url checksum_name checksum_url download_dir install_dir work_dir use_existing extract_dir root target temp_download_dir dir_name release_output
  product="$(normalize_product "$PRODUCT")"
  info=()
  release_output="$(release_info "$product" "$VERSION" 2>&1)" || die "$release_output"
  mapfile -t info <<< "$release_output"
  tag="${info[0]:-}" archive_name="${info[1]:-}" archive_url="${info[2]:-}" checksum_name="${info[3]:-}" checksum_url="${info[4]:-}"
  [[ -n "$tag" ]] || die "release not found for $product $VERSION"
  download_dir="$(expand_path "${DOWNLOAD_DIR:-$(xdg_download_dir)}")"
  install_dir="$(expand_path "${INSTALL_DIR:-$(default_install_dir)}")"
  dir_name="$(runner_target_dir_name "$product" "$VERSION" "$tag")"
  target="$install_dir/$dir_name"

  mkdir -p "$download_dir" "$install_dir"

  use_existing=0
  temp_download_dir=""
  extract_dir=""

  cleanup_install_failure() {
    [[ -n "$extract_dir" ]] && rm -rf "$extract_dir"
    [[ -n "$temp_download_dir" ]] && rm -rf "$temp_download_dir"
  }

  if [[ -s "$download_dir/$archive_name" && -s "$download_dir/$checksum_name" ]]; then
    work_dir="$download_dir"
    use_existing=1
    printf 'Using downloaded files in: %s\n' "$download_dir"
  else
    temp_download_dir="$(mktemp -d "$download_dir/.proton-install.XXXXXX")"
    work_dir="$temp_download_dir"
    if ! fetch_file "$archive_url" "$work_dir/$archive_name"; then
      cleanup_install_failure
      exit 1
    fi
    if ! fetch_file "$checksum_url" "$work_dir/$checksum_name"; then
      cleanup_install_failure
      exit 1
    fi
  fi

  if ! verify_archive "$work_dir" "$checksum_name"; then
    cleanup_install_failure
    exit 1
  fi

  extract_dir="$(mktemp -d)"
  if ! tar -xf "$work_dir/$archive_name" -C "$extract_dir"; then
    cleanup_install_failure
    die "failed to extract archive: $work_dir/$archive_name
The archive may be corrupted. Delete it and retry."
  fi
  root="$(find_extracted_runner_root "$extract_dir")" || {
    cleanup_install_failure
    die "extracted archive does not contain a proton runner: $work_dir/$archive_name"
  }
  if [[ -e "$target" && ! -x "$target/proton" ]]; then
    cleanup_install_failure
    die "install target exists but is not a runner: $target"
  fi
  if ! rm -rf "$target"; then
    cleanup_install_failure
    die "failed to remove old install target: $target"
  fi
  if ! mv "$root" "$target"; then
    cleanup_install_failure
    die "failed to install runner to: $target"
  fi
  printf '%s\n' "$tag" > "$target/.shorin-proton-wrapper-version"
  rm -rf "$extract_dir"
  extract_dir=""

  if [[ $use_existing -eq 0 ]]; then
    rm -rf "$work_dir"
    temp_download_dir=""
  elif [[ $CLEAN -eq 1 ]]; then
    rm -f "$download_dir/$archive_name" "$download_dir/$checksum_name"
  fi

  printf 'Installed: %s\n' "$target/proton"
}

update_runner() {
  local product target install_to_old old_product old_version release_output info tag current found updated skipped
  install_to_old="$INSTALL_TO"
  old_product="$PRODUCT"
  old_version="$VERSION"
  VERSION="latest"
  info=()
  found=0
  updated=0
  skipped=0

  for INSTALL_TO in local steam lutris; do
    for product in ge dw; do
      PRODUCT="$product"
      target="$(expand_path "$(default_install_dir)")/$(runner_dir_name "$product")"
      if [[ -e "$target" ]]; then
        found=1
        release_output="$(release_info "$product" latest 2>&1)" || die "$release_output"
        mapfile -t info <<< "$release_output"
        tag="${info[0]:-}"
        [[ -n "$tag" ]] || die "release not found for $product latest"
        current="$(installed_runner_version "$target" "$product" || true)"
        if [[ "$current" == "$tag" ]]; then
          printf 'Already latest: %s (%s)\n' "$target" "$tag"
          skipped=1
        else
          printf 'Updating: %s\n' "$target"
          if [[ -n "$current" ]]; then
            printf '  %s -> %s\n' "$current" "$tag"
          fi
          install_runner
          updated=1
        fi
      fi
    done
  done

  INSTALL_TO="$install_to_old"
  PRODUCT="$old_product"
  VERSION="$old_version"
  [[ $found -eq 1 ]] || die "no installed Latest runners found"
  if [[ $updated -eq 0 && $skipped -eq 1 ]]; then
    printf 'All installed Latest runners are up to date.\n'
  fi
}

remove_runner() {
  local product dir_name install_dir target lang
  product="$(normalize_product "$PRODUCT")"
  dir_name="$(runner_target_dir_name "$product" "$VERSION")"
  install_dir="$(expand_path "${INSTALL_DIR:-$(default_install_dir)}")"
  target="$install_dir/$dir_name"
  lang="$(ui_lang)"

  if [[ ! -e "$target" ]]; then
    if [[ "$lang" == "zh" ]]; then
      die "$dir_name 未安装"
    else
      die "$dir_name is not installed"
    fi
  fi

  rm -rf "$target"

  if [[ "$lang" == "zh" ]]; then
    printf '已移除: %s\n' "$target"
  else
    printf 'Removed: %s\n' "$target"
  fi
}

remove_all_runners() {
  local install_dir path removed lang
  install_dir="$(expand_path "${INSTALL_DIR:-$(default_install_dir)}")"
  lang="$(ui_lang)"
  removed=0

  shopt -s nullglob
  for path in "$install_dir"/*; do
    if [[ -d "$path" && -f "$path/.shorin-proton-wrapper-version" ]]; then
      rm -rf "$path"
      removed=1
      if [[ "$lang" == "zh" ]]; then
        printf '已移除: %s\n' "$path"
      else
        printf 'Removed: %s\n' "$path"
      fi
    fi
  done
  shopt -u nullglob

  if [[ $removed -eq 0 ]]; then
    if [[ "$lang" == "zh" ]]; then
      die "没有找到由 shorin-proton-wrapper 安装的运行器: $install_dir"
    else
      die "no runners installed by shorin-proton-wrapper found in: $install_dir"
    fi
  fi
}

ensure_runner_product() {
  local product="$1" old_product old_version old_install_to
  if try_resolve_runner_product "$product"; then
    return 0
  fi

  old_product="$PRODUCT"
  old_version="$VERSION"
  old_install_to="$INSTALL_TO"

  PRODUCT="$product"
  VERSION="latest"
  INSTALL_TO="local"
  install_runner

  PRODUCT="$old_product"
  VERSION="$old_version"
  INSTALL_TO="$old_install_to"

  try_resolve_runner_product "$product"
}

select_init_runner() {
  local product
  if [[ -n "$RUNNER_ARG" ]]; then
    if product="$(runner_product_alias "$RUNNER_ARG")"; then
      ensure_runner_product "$product" || die "failed to install runner: $product"
    else
      resolve_runner_arg "$RUNNER_ARG"
    fi
    return 0
  fi

  ensure_runner_product dw || die "failed to install runner: dw"
}

