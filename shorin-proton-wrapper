validate_resolution() {
  [[ "$1" =~ ^[0-9]+x[0-9]+$ ]] || die "invalid resolution: $1"
}

validate_number() {
  [[ "$1" =~ ^[0-9]+$ ]] || die "invalid number: $1"
}

prepare_mangohud_env() {
  MANGOHUD_ENV=()
  [[ $MANGOHUD -eq 1 ]] || return 0
  command -v mangohud >/dev/null 2>&1 || die "mangohud is not installed"
  MANGOHUD_ENV=("MANGOHUD=1")
}

append_gamescope_extra_args() {
  local extra="$1" tmp err status
  [[ -n "$extra" ]] || return 0
  tmp="$(mktemp)"
  err="$(mktemp)"
  python3 - "$extra" > "$tmp" 2> "$err" <<'PY'
import shlex
import sys

try:
    args = shlex.split(sys.argv[1])
except ValueError as exc:
    raise SystemExit(f"invalid Gamescope arguments: {exc}")

for arg in args:
    sys.stdout.write(arg)
    sys.stdout.write("\0")
PY
  status=$?
  if [[ $status -ne 0 ]]; then
    local message
    message="$(<"$err")"
    rm -f "$tmp" "$err"
    die "${message:-invalid Gamescope arguments: $extra}"
  fi
  mapfile -d '' -t GAMESCOPE_EXTRA_ARGS < "$tmp"
  rm -f "$tmp" "$err"
  GAMESCOPE_ARGS+=("${GAMESCOPE_EXTRA_ARGS[@]}")
}

build_gamescope_args() {
  GAMESCOPE_ARGS=()
  [[ $GAMESCOPE -eq 1 ]] || return 0
  command -v gamescope >/dev/null 2>&1 || die "gamescope is not installed"

  if [[ $GAMESCOPE_FULLSCREEN -eq 1 ]]; then
    GAMESCOPE_ARGS+=("-f")
  fi
  if [[ -n "$GAMESCOPE_RES" ]]; then
    validate_resolution "$GAMESCOPE_RES"
    GAMESCOPE_ARGS+=("-w" "${GAMESCOPE_RES%x*}" "-h" "${GAMESCOPE_RES#*x}")
  fi
  if [[ -n "$GAMESCOPE_FPS" ]]; then
    validate_number "$GAMESCOPE_FPS"
    GAMESCOPE_ARGS+=("-r" "$GAMESCOPE_FPS")
  fi
  if [[ $GAMESCOPE_FSR -eq 1 ]]; then
    GAMESCOPE_ARGS+=("-F" "fsr")
  fi
  append_gamescope_extra_args "$GAMESCOPE_EXTRA"
}

run_gamescope_proton_command() {
  local runner="$1"
  shift
  mkdir -p "$PREFIX"
  build_gamescope_args
  prepare_mangohud_env
  env \
    "${MANGOHUD_ENV[@]}" \
    "${DEBUG_ENV[@]}" \
    "${CACHED_ENV[@]}" \
    STEAM_COMPAT_DATA_PATH="$PREFIX" \
    STEAM_COMPAT_CLIENT_INSTALL_PATH="$(steam_root_dir)" \
    SteamAppId="${SteamAppId:-0}" \
    SteamGameId="${SteamGameId:-0}" \
    UMU_ID="${UMU_ID:-shorin-proton-wrapper}" \
    UMU_USE_STEAM="${UMU_USE_STEAM:-0}" \
    gamescope "${GAMESCOPE_ARGS[@]}" -- "$runner" "$@"
}

