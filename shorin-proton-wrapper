apply_cached_env_vars() {
  local encoded="$1" tmp status
  CACHED_ENV=()
  [[ -n "$encoded" ]] || return 0
  tmp="$(mktemp)"
  python3 - "$encoded" > "$tmp" <<'PY'
import shlex
import sys
from urllib.parse import unquote

text = unquote(sys.argv[1])
try:
    parts = shlex.split(text)
except ValueError:
    parts = [line.strip() for line in text.splitlines()]
for part in parts:
    if "=" not in part or part.startswith("="):
        continue
    sys.stdout.write(part)
    sys.stdout.write("\0")
PY
  status=$?
  if [[ $status -eq 0 ]]; then
    mapfile -d '' -t CACHED_ENV < "$tmp"
  fi
  rm -f "$tmp"
}

association_cache_file_for() {
  local target_path="$1" cache_dir key
  cache_dir="$XDG_CACHE_HOME_VALUE/shorin-proton-wrapper/associations"
  key="$(printf '%s' "$target_path" | sha256sum | cut -d ' ' -f 1)"
  printf '%s/%s.conf\n' "$cache_dir" "$key"
}

should_record_association() {
  local target_path="$1" name
  name="$(basename "$target_path")"
  name="${name%.*}"
  name="${name,,}"
  case "$name" in
    *setup*|*install*|*installer*|*uninstall*|unins*|*update*|*updater*|*patch*|*crash*|*helper*|*redist*|*vcredist*|*vc_redist*|dxsetup)
      return 1
      ;;
  esac
  return 0
}

record_default_association() {
  local target_path="$1" cache_file
  case "${target_path,,}" in
    *.exe|*.lnk) ;;
    *) return 0 ;;
  esac
  should_record_association "$target_path" || return 0
  cache_file="$(association_cache_file_for "$target_path")"
  [[ -e "$cache_file" ]] && return 0
  mkdir -p "$(dirname "$cache_file")"
  cat > "$cache_file" <<EOF
exe=$target_path
prefix=$PREFIX
runner=$RESOLVED_RUNNER_PATH
gamescope=$GAMESCOPE
gamescope_fullscreen=$GAMESCOPE_FULLSCREEN
gamescope_res=$GAMESCOPE_RES
gamescope_fps=$GAMESCOPE_FPS
gamescope_fsr=$GAMESCOPE_FSR
gamescope_args=$GAMESCOPE_EXTRA
mangohud=$MANGOHUD
env_vars=
source=auto
EOF
}

apply_cached_association() {
  local target_path="$1" cache_dir key cache_file line name value
  local cache_prefix="" cache_runner="" cache_gamescope="0" cache_fullscreen="0"
  local cache_res="" cache_fps="" cache_fsr="0" cache_args="" cache_mangohud="0" cache_env_vars=""

  cache_file="$(association_cache_file_for "$target_path")"
  [[ -r "$cache_file" ]] || return 0

  while IFS= read -r line; do
    [[ "$line" == *=* ]] || continue
    name="${line%%=*}"
    value="${line#*=}"
    case "$name" in
      prefix) cache_prefix="$value" ;;
      runner) cache_runner="$value" ;;
      gamescope) cache_gamescope="$value" ;;
      gamescope_fullscreen) cache_fullscreen="$value" ;;
      gamescope_res) cache_res="$value" ;;
      gamescope_fps) cache_fps="$value" ;;
      gamescope_fsr) cache_fsr="$value" ;;
      gamescope_args) cache_args="$value" ;;
      mangohud) cache_mangohud="$value" ;;
      env_vars) cache_env_vars="$value" ;;
    esac
  done < "$cache_file"

  [[ -n "$cache_prefix" && -d "$cache_prefix" ]] || return 0
  [[ -n "$cache_runner" && -x "$cache_runner" ]] || return 0
  [[ "$cache_gamescope" == "1" ]] || cache_gamescope="0"
  [[ "$cache_fullscreen" == "1" ]] || cache_fullscreen="0"
  [[ "$cache_fsr" == "1" ]] || cache_fsr="0"
  [[ "$cache_mangohud" == "1" ]] || cache_mangohud="0"

  if [[ $PREFIX_EXPLICIT -eq 0 ]]; then
    PREFIX="$cache_prefix"
  fi
  if [[ $RUNNER_EXPLICIT -eq 0 ]]; then
    RUNNER_ARG="$cache_runner"
  fi
  if [[ $GAMESCOPE_EXPLICIT -eq 0 ]]; then
    GAMESCOPE="$cache_gamescope"
    GAMESCOPE_FULLSCREEN="$cache_fullscreen"
    GAMESCOPE_RES="$cache_res"
    GAMESCOPE_FPS="$cache_fps"
    GAMESCOPE_FSR="$cache_fsr"
    GAMESCOPE_EXTRA="$cache_args"
  fi
  if [[ $MANGOHUD_EXPLICIT -eq 0 ]]; then
    MANGOHUD="$cache_mangohud"
  fi
  apply_cached_env_vars "$cache_env_vars"
}

open_winecfg() {
  select_runner
  if [[ "$RESOLVED_RUNNER_TYPE" == "proton" ]]; then
    exec_proton_command "$RESOLVED_RUNNER_PATH" run winecfg
  else
    exec_wine_command "$RESOLVED_RUNNER_PATH" winecfg
  fi
}

prepare_mapped_drive_target() {
  local target_path="$1" source_dir base dosdevices marker letter link
  target_path="$(realpath -m "$target_path")"
  source_dir="$(dirname "$target_path")"
  base="$(basename "$target_path")"
  proton_exe="$target_path"

  case "$target_path" in
    "$PREFIX/pfx/drive_c"/*)
      workdir="$source_dir"
      exe="./$base"
      return 0
      ;;
  esac

  dosdevices="$PREFIX/pfx/dosdevices"
  marker="$PREFIX/.shorin-proton-wrapper-drive"
  mkdir -p "$dosdevices"

  if [[ -r "$marker" ]]; then
    letter="$(sed -n '1p' "$marker")"
    link="$dosdevices/$letter:"
    if [[ "$letter" =~ ^[d-y]$ && ( ! -e "$link" || -L "$link" ) ]]; then
      rm -f "$link"
      ln -s "$source_dir" "$link"
      workdir="$PREFIX/pfx/drive_c"
      exe="${letter}:\\$base"
      return 0
    fi
  fi

  for letter in d e f g h i j k l m n o p q r s t u v w x y; do
    link="$dosdevices/$letter:"
    if [[ ! -e "$link" && ! -L "$link" ]]; then
      ln -s "$source_dir" "$link"
      printf '%s\n' "$letter" > "$marker"
      workdir="$PREFIX/pfx/drive_c"
      exe="${letter}:\\$base"
      return 0
    fi
  done

  die "no free Wine drive letter found for: $source_dir"
}

run_target() {
  local workdir exe proton_exe status
  TARGET="$(expand_path "$TARGET")"
  [[ -e "$TARGET" ]] || die "target not found: $TARGET"
  apply_cached_association "$TARGET"
  PREFIX="$(expand_path "$PREFIX")"
  select_runner
  ensure_initialized
  record_default_association "$TARGET"

  case "${TARGET,,}" in
    *.lnk)
      if [[ "$RESOLVED_RUNNER_TYPE" == "proton" ]]; then
        exec_proton_command "$RESOLVED_RUNNER_PATH" waitforexitandrun start /unix "$TARGET" "${TARGET_ARGS[@]}"
      else
        exec_wine_command "$RESOLVED_RUNNER_PATH" start /unix "$TARGET" "${TARGET_ARGS[@]}"
      fi
      ;;
  esac

  prepare_mapped_drive_target "$TARGET"

  cd "$workdir"
  set +e
  if [[ "$RESOLVED_RUNNER_TYPE" == "proton" ]]; then
    if [[ $GAMESCOPE -eq 1 ]]; then
      run_gamescope_proton_command "$RESOLVED_RUNNER_PATH" waitforexitandrun "$proton_exe" "${TARGET_ARGS[@]}"
    else
      run_proton_command "$RESOLVED_RUNNER_PATH" waitforexitandrun "$proton_exe" "${TARGET_ARGS[@]}"
    fi
    status=$?
  else
    if [[ $GAMESCOPE -eq 1 ]]; then
      run_gamescope_wine_command "$RESOLVED_RUNNER_PATH" "$exe" "${TARGET_ARGS[@]}"
    else
      run_wine_command "$RESOLVED_RUNNER_PATH" "$exe" "${TARGET_ARGS[@]}"
    fi
    status=$?
  fi
  set -e
  exit "$status"
}

show_status() {
  local runner_type runner_path initialized install_dir download_dir lang
  PREFIX="$(expand_path "$PREFIX")"
  download_dir="$(expand_path "${DOWNLOAD_DIR:-$(xdg_download_dir)}")"
  install_dir="$(expand_path "${INSTALL_DIR:-$(default_install_dir)}")"
  lang="$(ui_lang)"

  runner_type="not found"
  runner_path="not found"
  if try_select_runner >/dev/null 2>&1; then
    runner_type="$RESOLVED_RUNNER_TYPE"
    runner_path="$RESOLVED_RUNNER_PATH"
  fi

  initialized="no"
  if [[ -d "$PREFIX/pfx" ]]; then
    initialized="yes"
  fi

  if [[ "$lang" == "zh" ]]; then
    [[ "$initialized" == "yes" ]] && initialized="是" || initialized="否"
    printf '前置环境:   %s\n' "$PREFIX"
    printf 'PFX:        %s\n' "$PREFIX/pfx"
    printf '已初始化:   %s\n' "$initialized"
    printf '运行器类型: %s\n' "$runner_type"
    printf '运行器:     %s\n' "$runner_path"
    printf '下载目录:   %s\n' "$download_dir"
    printf '安装目录:   %s\n' "$install_dir"
  else
    printf 'Prefix:      %s\n' "$PREFIX"
    printf 'PFX:         %s\n' "$PREFIX/pfx"
    printf 'Initialized: %s\n' "$initialized"
    printf 'Runner type: %s\n' "$runner_type"
    printf 'Runner:      %s\n' "$runner_path"
    printf 'Download:    %s\n' "$download_dir"
    printf 'Install dir: %s\n' "$install_dir"
  fi
}

parse_args() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      --help-full)
        usage_full
        exit 0
        ;;
      --lang)
        [[ $# -ge 2 ]] || die "$1 requires zh or en"
        case "${2,,}" in
          zh|en) LANG_OVERRIDE="${2,,}" ;;
          *) die "unsupported language: $2" ;;
        esac
        shift 2
        ;;
      -p|--prefix)
        [[ $# -ge 2 ]] || die "$1 requires a directory"
        PREFIX="$2"
        PREFIX_EXPLICIT=1
        shift 2
        ;;
      --runner)
        [[ $# -ge 2 ]] || die "$1 requires a path"
        RUNNER_ARG="$2"
        RUNNER_EXPLICIT=1
        shift 2
        ;;
      --gs|--gamescope)
        GAMESCOPE=1
        GAMESCOPE_EXPLICIT=1
        shift
        while [[ $# -gt 0 ]]; do
          case "$1" in
            -h|--help)
              gamescope_usage
              exit 0
              ;;
            --windowed)
              GAMESCOPE_FULLSCREEN=0
              shift
              ;;
            --fullscreen)
              GAMESCOPE_FULLSCREEN=1
              shift
              ;;
            --res)
              [[ $# -ge 2 ]] || die "$1 requires WIDTHxHEIGHT"
              validate_resolution "$2"
              GAMESCOPE_RES="$2"
              shift 2
              ;;
            --fps)
              [[ $# -ge 2 ]] || die "$1 requires FPS"
              validate_number "$2"
              GAMESCOPE_FPS="$2"
              shift 2
              ;;
            --fsr)
              GAMESCOPE_FSR=1
              shift
              ;;
            --args)
              [[ $# -ge 2 ]] || die "$1 requires arguments"
              GAMESCOPE_EXTRA="$2"
              shift 2
              ;;
            --)
              shift
              break
              ;;
            --*)
              break
              ;;
            *)
              break
              ;;
          esac
        done
        ;;
      --mangohud)
        MANGOHUD=1
        MANGOHUD_EXPLICIT=1
        shift
        ;;
      --debug)
        DEBUG=1
        shift
        ;;
      -d|--directory)
        [[ $# -ge 2 ]] || die "$1 requires a directory"
        DOWNLOAD_DIR="$2"
        shift 2
        ;;
      --version)
        [[ $# -ge 2 ]] || die "$1 requires a version"
        VERSION="$2"
        shift 2
        ;;
      --clean)
        CLEAN=1
        shift
        ;;
      --list-runner)
        ACTION="list"
        shift
        ;;
      --list-version)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="list-version"
        PRODUCT="$2"
        shift 2
        ;;
      --status)
        ACTION="status"
        shift
        ;;
      --init)
        ACTION="init"
        shift
        ;;
      --winecfg)
        ACTION="winecfg"
        shift
        ;;
      --download)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="download"
        PRODUCT="$2"
        shift 2
        ;;
      --install)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="install"
        PRODUCT="$2"
        shift 2
        ;;
      --install-steam)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="install"
        PRODUCT="$2"
        INSTALL_TO="steam"
        shift 2
        ;;
      --install-lutris)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="install"
        PRODUCT="$2"
        INSTALL_TO="lutris"
        shift 2
        ;;
      --update)
        ACTION="update"
        shift
        ;;
      --remove)
        [[ $# -ge 2 ]] || die "$1 requires ge or dw"
        ACTION="remove"
        PRODUCT="$2"
        shift 2
        ;;
      --remove-steam)
        INSTALL_TO="steam"
        if [[ $# -ge 2 && ! "$2" =~ ^- ]]; then
          ACTION="remove"
          PRODUCT="$2"
          shift 2
        else
          ACTION="remove-all"
          shift
        fi
        ;;
      --remove-lutris)
        INSTALL_TO="lutris"
        if [[ $# -ge 2 && ! "$2" =~ ^- ]]; then
          ACTION="remove"
          PRODUCT="$2"
          shift 2
        else
          ACTION="remove-all"
          shift
        fi
        ;;
      --)
        shift
        [[ $# -ge 1 ]] || die "-- requires a target"
        TARGET="$1"
        shift
        TARGET_ARGS=("$@")
        break
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -z "$ACTION" ]]; then
          TARGET="$1"
          shift
          TARGET_ARGS=("$@")
          break
        fi
        die "unexpected argument for $ACTION: $1"
        ;;
    esac
  done
}

parse_args "$@"
PREFIX="$(expand_path "$PREFIX")"
setup_debug_logging

case "$ACTION" in
  list)
    list_runners
    ;;
  list-version)
    list_versions "$PRODUCT"
    ;;
  status)
    show_status
    ;;
  init)
    init_prefix
    ;;
  winecfg)
    open_winecfg
    ;;
  download)
    download_runner
    ;;
  install)
    install_runner
    ;;
  update)
    update_runner
    ;;
  remove)
    remove_runner
    ;;
  remove-all)
    remove_all_runners
    ;;
  "")
    if [[ -z "$TARGET" ]]; then
      if [[ $GAMESCOPE -eq 1 ]]; then
        gamescope_usage
        exit 0
      fi
      die "no target provided"
    fi
    run_target
    ;;
  *)
    die "unknown action: $ACTION"
    ;;
esac
