#!/usr/bin/env bash
set -euo pipefail

ORIGINAL_ARGS=("$@")
DEFAULT_PREFIX="${PROTON_PREFIX:-$HOME/.proton}"
XDG_DATA_HOME_VALUE="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_CACHE_HOME_VALUE="${XDG_CACHE_HOME:-$HOME/.cache}"
LOCAL_RUNNER_DIR="$XDG_DATA_HOME_VALUE/proton/runners"
STEAM_ROOT="${STEAM_COMPAT_CLIENT_INSTALL_PATH:-$HOME/.steam/root}"

ACTION=""
PRODUCT=""
VERSION="latest"
PREFIX="$DEFAULT_PREFIX"
RUNNER_ARG="${PROTON_RUNNER:-}"
DOWNLOAD_DIR=""
INSTALL_DIR=""
INSTALL_TO="local"
CLEAN=0
TARGET=""
TARGET_ARGS=()
LANG_OVERRIDE="${PROTON_LANG:-}"
GAMESCOPE=0
GAMESCOPE_FULLSCREEN=0
GAMESCOPE_RES=""
GAMESCOPE_FPS=""
GAMESCOPE_FSR=0
GAMESCOPE_EXTRA=""
MANGOHUD=0
DEBUG=0
DEBUG_LOG=""
PREFIX_EXPLICIT=0
RUNNER_EXPLICIT=0
GAMESCOPE_EXPLICIT=0
MANGOHUD_EXPLICIT=0

if [[ "$0" == */* ]]; then
  SELF_PATH="$(realpath -m "$0")"
else
  SELF_PATH="$(command -v shorin-proton-wrapper || printf 'shorin-proton-wrapper')"
fi

RUNNER_TYPES=()
RUNNER_SOURCES=()
RUNNER_NAMES=()
RUNNER_PATHS=()
DEBUG_ENV=()
CACHED_ENV=()
declare -A RUNNER_SEEN=()

[[ -n "${PROTON_PREFIX:-}" ]] && PREFIX_EXPLICIT=1
[[ -n "${PROTON_RUNNER:-}" ]] && RUNNER_EXPLICIT=1

ui_lang() {
  local locale="${LANG_OVERRIDE:-${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}}"
  case "${locale,,}" in
    zh|zh_*|zh.*|zh-*) printf 'zh\n' ;;
    *) printf 'en\n' ;;
  esac
}

setup_debug_logging() {
  local log_dir name timestamp
  [[ $DEBUG -eq 1 ]] || return 0

  log_dir="$XDG_CACHE_HOME_VALUE/shorin-proton-wrapper/logs"
  mkdir -p "$log_dir"
  name="${TARGET:-${ACTION:-command}}"
  name="$(basename "${name:-command}")"
  name="$(printf '%s' "$name" | tr -c 'A-Za-z0-9._-' '_')"
  timestamp="$(date +%Y%m%d-%H%M%S)"
  DEBUG_LOG="$log_dir/$timestamp-$name.log"
  DEBUG_ENV=("PROTON_LOG=1" "PROTON_LOG_DIR=$log_dir")

  exec > >(tee -a "$DEBUG_LOG") 2>&1
  printf 'Debug log: %s\n' "$DEBUG_LOG"
  printf 'Command: shorin-proton-wrapper'
  printf ' %q' "${ORIGINAL_ARGS[@]}"
  printf '\n'
}

