    def on_cache_edit_response(self, dialog, response, entry: dict[str, str], widgets: dict) -> None:
        if response == Gtk.ResponseType.ACCEPT:
            entry["exe"] = widgets["exe"].get_text().strip()
            entry["prefix"] = widgets["prefix"].get_text().strip()
            entry["runner"] = self.runner_combo_path(widgets["runner"])
            entry["gamescope_res"] = self.combo_entry_text(widgets["gamescope_res"])
            entry["gamescope_fps"] = self.combo_entry_text(widgets["gamescope_fps"])
            entry["gamescope_args"] = widgets["gamescope_args"].get_text().strip()
            entry["env_vars"] = widgets["env_vars"].get_text().strip()
            for key in ("gamescope", "gamescope_fullscreen", "gamescope_fsr", "mangohud"):
                entry[key] = "1" if widgets[key].get_active() else "0"
            entry["source"] = "configured"
            write_cache_entry(entry)
            self.set_status(f"{TEXT['reconfigure']}: {entry.get('exe', '')}")
            self.reload_prefixes()
            self.refresh_all()
        dialog.destroy()

    def delete_cache(self, file_path: str) -> None:
        if file_path:
            Path(file_path).unlink(missing_ok=True)
        self.reload_prefixes()
        self.refresh_all()

