    candidates = []
    for suffix in (".png", ".svg", ".ico", ".xpm"):
        candidates.append(path.with_suffix(suffix))
    return candidates


def read_lnk_string(data: bytes, offset: int, unicode: bool) -> tuple[str, int]:
    if offset + 2 > len(data):
        return "", offset
    length = struct.unpack_from("<H", data, offset)[0]
    offset += 2
    if unicode:
        size = length * 2
        raw = data[offset:offset + size]
        return raw.decode("utf-16le", errors="ignore").rstrip("\0"), offset + size
    raw = data[offset:offset + length]
    return raw.decode("mbcs" if os.name == "nt" else "latin-1", errors="ignore").rstrip("\0"), offset + length


def parse_lnk(path: Path) -> dict[str, str]:
    try:
        data = path.read_bytes()
    except OSError:
        return {}
    if len(data) < 0x4C or data[:4] != b"L\0\0\0":
        return {}
    flags = struct.unpack_from("<I", data, 0x14)[0]
    is_unicode = bool(flags & 0x80)
    offset = 0x4C
    result = {}

    if flags & 0x01:
        if offset + 2 > len(data):
            return result
        id_list_size = struct.unpack_from("<H", data, offset)[0]
        offset += 2 + id_list_size

    if flags & 0x02:
        if offset + 4 > len(data):
            return result
        link_info_size = struct.unpack_from("<I", data, offset)[0]
        link_info = data[offset:offset + link_info_size]
        if len(link_info) >= 0x1C:
            try:
                header_size = struct.unpack_from("<I", link_info, 4)[0]
                local_base_offset = struct.unpack_from("<I", link_info, 16)[0]
                suffix_offset = struct.unpack_from("<I", link_info, 24)[0]
                local_base = ""
                suffix = ""
                if local_base_offset and local_base_offset < len(link_info):
                    local_base = link_info[local_base_offset:].split(b"\0", 1)[0].decode("mbcs" if os.name == "nt" else "latin-1", errors="ignore")
                if suffix_offset and suffix_offset < len(link_info):
                    suffix = link_info[suffix_offset:].split(b"\0", 1)[0].decode("mbcs" if os.name == "nt" else "latin-1", errors="ignore")
                if header_size >= 0x24 and len(link_info) >= 0x24:
                    local_base_unicode_offset = struct.unpack_from("<I", link_info, 28)[0]
                    suffix_unicode_offset = struct.unpack_from("<I", link_info, 32)[0]
                    if local_base_unicode_offset and local_base_unicode_offset < len(link_info):
                        local_base = link_info[local_base_unicode_offset:].split(b"\0\0", 1)[0].decode("utf-16le", errors="ignore")
                    if suffix_unicode_offset and suffix_unicode_offset < len(link_info):
                        suffix = link_info[suffix_unicode_offset:].split(b"\0\0", 1)[0].decode("utf-16le", errors="ignore")
                target = local_base
                if suffix and local_base and not local_base.lower().endswith(suffix.lower()):
                    target = local_base.rstrip("\\/") + "\\" + suffix.lstrip("\\/")
                if target:
                    result["target"] = target
            except (struct.error, UnicodeError):
                pass
        offset += link_info_size

    for flag in (0x04, 0x08, 0x10, 0x20, 0x40):
        if not flags & flag:
            continue
        value, offset = read_lnk_string(data, offset, is_unicode)
        if flag == 0x40:
            result["icon"] = value
    return result


def parse_lnk_icon_location(path: Path) -> str:
    return parse_lnk(path).get("icon", "")


def parse_lnk_target(path: Path) -> str:
    return parse_lnk(path).get("target", "")


def windows_path_to_linux(prefix: Path, value: str) -> Path | None:
    value = value.strip().strip('"')
    if not value:
        return None
    env_map = {
        "%SystemRoot%": "C:\\windows",
        "%windir%": "C:\\windows",
        "%ProgramFiles%": "C:\\Program Files",
        "%ProgramFiles(x86)%": "C:\\Program Files (x86)",
        "%ProgramData%": "C:\\ProgramData",
        "%USERPROFILE%": f"C:\\users\\{os.environ.get('USER', '')}",
    }
    for key, replacement in env_map.items():
        value = value.replace(key, replacement)
    value = value.replace("/", "\\")
    if len(value) >= 3 and value[1] == ":" and value[2] == "\\":
        drive = value[0].lower()
        rest = value[3:].replace("\\", "/")
        if drive == "c":
            return prefix / "pfx" / "drive_c" / rest
        return prefix / "pfx" / "dosdevices" / f"{drive}:" / rest
    candidate = Path(value).expanduser()
    if candidate.is_absolute():
        return candidate
    return None


def icon_cache_key(source: Path, icon_index: str = "") -> str:
    try:
        stat = source.stat()
        seed = f"{source}\0{stat.st_mtime_ns}\0{stat.st_size}\0{icon_index}"
    except OSError:
        seed = f"{source}\0{icon_index}"
    return hashlib.sha256(seed.encode()).hexdigest()[:16]


def convert_icon_to_png(source: Path, target: Path) -> bool:
    try:
        from PIL import Image
    except ImportError:
        return False
    try:
        image = Image.open(source)
        frames = []
        for index in range(getattr(image, "n_frames", 1)):
            image.seek(index)
            frames.append(image.copy().convert("RGBA"))
        if not frames:
            return False
        best = max(frames, key=lambda item: item.width * item.height)
        if best.width > 256 or best.height > 256:
            best.thumbnail((256, 256), Image.LANCZOS)
        target.parent.mkdir(parents=True, exist_ok=True)
        best.save(target, "PNG")
        return True
    except Exception:
        target.unlink(missing_ok=True)
        return False


def extract_exe_icon_to_png(source: Path, target: Path) -> bool:
    icoextract = shutil_which("icoextract")
    if not icoextract:
        return False
    target.parent.mkdir(parents=True, exist_ok=True)
    tmp = target.with_suffix(".ico.tmp")
    try:
        result = subprocess.run([icoextract, str(source), str(tmp)], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        return False
    if result.returncode != 0 or not tmp.is_file() or tmp.stat().st_size == 0:
        tmp.unlink(missing_ok=True)
        return False
    ok = convert_icon_to_png(tmp, target)
    tmp.unlink(missing_ok=True)
    return ok


def extracted_icon_path(prefix: Path, source: Path, app_name: str, target_dir: Path | None = None) -> Path | None:
    target_dir = target_dir or gui_icon_dir()
    key = icon_cache_key(source)
    target = target_dir / f"{safe_filename(app_name)}-{key}.png"
    if target.is_file() and target.stat().st_size > 0:
        return target
    if source.suffix.lower() == ".ico" and source.is_file():
        return target if convert_icon_to_png(source, target) else None
    if source.suffix.lower() not in (".exe", ".dll", ".icl") or not source.is_file():
        return None
    if extract_exe_icon_to_png(source, target):
        return target
    wrestool = shutil_which("wrestool")
    if not wrestool:
        return None
    tmp = target.with_suffix(".ico.tmp")
    try:
        result = subprocess.run([wrestool, "-x", "-t", "14", str(source)], check=False, stdout=subprocess.PIPE)
    except OSError:
        return None
    if result.returncode == 0 and result.stdout:
        tmp.write_bytes(result.stdout)
        if convert_icon_to_png(tmp, target):
            tmp.unlink(missing_ok=True)
            return target
        tmp.unlink(missing_ok=True)
    return None


def search_icon_tree(root: Path, app_name: str, limit: int = 3000) -> Path | None:
    if not root.is_dir():
        return None
    wanted = normalize_icon_name(app_name)
    if not wanted:
        return None
    best = None
    scanned = 0
    for pattern in ("*.png", "*.svg", "*.ico", "*.xpm"):
        for icon in root.rglob(pattern):
            scanned += 1
            if scanned > limit:
                return best
            name = normalize_icon_name(icon.stem)
            if name == wanted:
                return icon
            if wanted in name or name in wanted:
                best = best or icon
    return best


def icon_for_app(prefix: Path, app: dict[str, str], target_dir: Path | None = None) -> str:
    path = Path(app["path"])
    if path.suffix.lower() == ".lnk":
        icon_location = parse_lnk_icon_location(path)
        icon_source = windows_path_to_linux(prefix, icon_location) if icon_location else None
        if icon_source:
            extracted = extracted_icon_path(prefix, icon_source, app["name"], target_dir)
            if extracted:
                return str(extracted)
        target_location = app.get("target_exe") or parse_lnk_target(path)
        target_source = windows_path_to_linux(prefix, target_location) if target_location else None
        if target_source:
            extracted = extracted_icon_path(prefix, target_source, app["name"], target_dir)
            if extracted:
                return str(extracted)
    else:
        extracted = extracted_icon_path(prefix, path, app["name"], target_dir)
        if extracted:
            return str(extracted)

    for candidate in icon_candidates_near(path):
        if candidate.is_file():
            return str(candidate)

    for root in (
        prefix / "pfx" / "drive_c" / "windows" / "Installer",
        prefix / "pfx" / "drive_c" / "ProgramData",
    ):
        icon = search_icon_tree(root, app["name"])
        if icon:
            return str(icon)

    return "shorin-proton"


