def expand_path(value: str | Path) -> Path:
    return Path(value).expanduser().resolve(strict=False)


def cache_home() -> Path:
    return Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))


def data_home() -> Path:
    return Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share"))


def association_dir() -> Path:
    return cache_home() / "shorin-proton-wrapper" / "associations"


def gui_icon_dir() -> Path:
    return cache_home() / "shorin-proton-wrapper" / "icons"


def exported_icon_dir() -> Path:
    return data_home() / "icons" / "shorin-proton-wrapper" / "apps"


def exported_app_dir() -> Path:
    return data_home() / "applications" / "shorin-proton-wrapper"


def resolve_sibling(name: str) -> str:
    candidate = Path(__file__).resolve().with_name(name)
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return str(candidate)
    return name


def read_key_values(path: Path) -> dict[str, str]:
    data = {}
    if not path.is_file():
        return data
    for line in path.read_text(errors="ignore").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if key == "env_vars":
            value = unquote(value)
        data[key] = value
    return data


def collect_prefixes() -> list[Path]:
    values = [expand_path(os.environ.get("PROTON_PREFIX", Path.home() / ".proton"))]
    for conf in association_dir().glob("*.conf"):
        prefix = read_key_values(conf).get("prefix")
        if prefix:
            values.append(expand_path(prefix))
    seen = set()
    result = []
    for prefix in values:
        key = str(prefix)
        if key in seen:
            continue
        seen.add(key)
        result.append(prefix)
    return result


def cache_file_for_path(exe: str | Path) -> Path:
    association_dir().mkdir(parents=True, exist_ok=True)
    key = hashlib.sha256(str(exe).encode()).hexdigest()
    return association_dir() / f"{key}.conf"


def parse_runners(output: str) -> list[dict[str, str]]:
    runners = []
    name = kind = source = ""
    for line in output.splitlines():
        if not line.strip():
            continue
        if ":" not in line:
            name = line.strip().removeprefix("* ").strip()
        elif line.startswith("      type:   "):
            kind = line.removeprefix("      type:   ")
        elif line.startswith("      source: "):
            source = line.removeprefix("      source: ")
        elif line.startswith("      path:   "):
            runners.append({
                "name": name,
                "type": kind,
                "source": source,
                "path": line.removeprefix("      path:   "),
            })
    return runners


def load_runners(wrapper: str) -> list[dict[str, str]]:
    try:
        result = subprocess.run([wrapper, "--list-runner"], check=False, text=True, capture_output=True)
    except OSError:
        return []
    return parse_runners(result.stdout)


def runner_label(runner: dict[str, str]) -> str:
    detail = runner.get("source") or runner.get("type")
    return f'{runner["name"]} · {detail}' if detail else runner["name"]


def safe_filename(value: str) -> str:
    cleaned = []
    for char in value:
        if char.isalnum() or char in ".-_":
            cleaned.append(char)
        elif char.isspace():
            cleaned.append("-")
        else:
            cleaned.append("_")
    name = "".join(cleaned).strip("-._")
    return name or "windows-app"


GENERIC_EXE_NAMES = {
    "app", "bootstrap", "client", "game", "launcher", "launcher_main", "main", "run", "start",
}

GENERIC_DIR_NAMES = {
    "bin", "build", "debug", "dist", "files", "release", "runtime", "runtimes", "win32", "win64", "x64", "x86",
}

COMMON_RESOLUTIONS = ["1280x720", "1600x900", "1920x1080", "2560x1440", "3840x2160"]
COMMON_FPS = ["30", "40", "45", "60", "90", "120", "144", "165", "240"]


def is_resolution(value: str) -> bool:
    parts = value.lower().split("x", 1)
    return len(parts) == 2 and parts[0].isdigit() and parts[1].isdigit()


def is_number(value: str) -> bool:
    return value.isdigit()


def display_modes() -> tuple[list[str], list[str]]:
    resolutions = []
    refresh_rates = []
    display = Gdk.Display.get_default()
    if not display:
        return resolutions, refresh_rates
    monitors = display.get_monitors()
    for index in range(monitors.get_n_items()):
        monitor = monitors.get_item(index)
        if not monitor:
            continue
        geometry = monitor.get_geometry()
        if geometry.width > 0 and geometry.height > 0:
            resolutions.append(f"{geometry.width}x{geometry.height}")
        refresh = monitor.get_refresh_rate()
        if refresh > 0:
            refresh_rates.append(str(round(refresh / 1000)))
    return resolutions, refresh_rates


def unique_preserve_order(values: list[str]) -> list[str]:
    seen = set()
    result = []
    for value in values:
        if value and value not in seen:
            seen.add(value)
            result.append(value)
    return result


def resolution_options() -> list[str]:
    current, _refresh = display_modes()
    max_width = max((int(value.split("x", 1)[0]) for value in current if is_resolution(value)), default=3840)
    max_height = max((int(value.split("x", 1)[1]) for value in current if is_resolution(value)), default=2160)
    common = [
        value for value in COMMON_RESOLUTIONS
        if int(value.split("x", 1)[0]) <= max_width and int(value.split("x", 1)[1]) <= max_height
    ]
    return unique_preserve_order(current + common)


def fps_options() -> list[str]:
    _resolutions, current = display_modes()
    current_numbers = [int(value) for value in current if is_number(value)]
    max_refresh = max(current_numbers, default=144)
    common = [value for value in COMMON_FPS if int(value) <= max_refresh]
    return unique_preserve_order(current + common)


def version_like(value: str) -> bool:
    parts = value.replace("_", ".").replace("-", ".").split(".")
    return len(parts) > 1 and all(part.isdigit() for part in parts if part)


def windows_install_roots(prefix: Path) -> list[Path]:
    pfx = prefix / "pfx" / "drive_c"
    user = os.environ.get("USER", "")
    return [
        pfx / "Program Files",
        pfx / "Program Files (x86)",
        pfx / "users" / user / "AppData" / "Local",
        pfx / "users" / user / "AppData" / "Roaming",
    ]


def under_known_install_root(prefix: Path, path: Path) -> bool:
    path = expand_path(path)
    for root in windows_install_roots(prefix):
        try:
            path.relative_to(root)
            return True
        except ValueError:
            continue
    return False


def inferred_exe_name(path: Path, prefix: Path | None = None) -> str:
    stem = path.stem
    if stem.lower() not in GENERIC_EXE_NAMES:
        return stem
    if prefix is None or not under_known_install_root(prefix, path):
        return stem
    for parent in path.parents:
        name = parent.name
        lower = name.lower()
        if not name or lower in GENERIC_DIR_NAMES or version_like(name):
            continue
        if lower in {"program files", "program files (x86)", "drive_c", "pfx"}:
            break
        return name
    return stem


def app_key(prefix: Path, path: Path) -> str:
    return hashlib.sha256((str(prefix) + "\0" + str(path)).encode()).hexdigest()[:10]


def app_identity(prefix: Path, path: Path) -> str:
    return app_key(prefix, path)


