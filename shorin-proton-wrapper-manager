    def on_rename_app_response(self, dialog, response, app: dict[str, str], entry: Gtk.Entry) -> None:
        if response == Gtk.ResponseType.ACCEPT:
            name = entry.get_text().strip() or app_display_name(app)
            cache_entry = app_cache_entry(self.page_prefix("apps"), app)
            cache_entry["name"] = name
            write_cache_entry(cache_entry)
            desktop = exported_desktop_path(self.page_prefix("apps"), app)
            if desktop.is_file():
                rewrite_desktop_name(desktop, name)
            self.set_status(f"{TEXT['rename']}: {name}")
        dialog.destroy()
        self.refresh_apps()

    def delete_library_item(self, app: dict[str, str]) -> None:
        desktop = delete_exported_app(self.page_prefix("apps"), app)
        file_path = app.get("file") or str(cache_file_for_path(app["path"]))
        Path(file_path).unlink(missing_ok=True)
        maybe_update_desktop_database()
        self.set_status(f"{TEXT['removed']}: {desktop}")
        self.refresh_apps()

    def kill_process(self, proc: dict[str, str], force: bool) -> None:
        try:
            kill_pid(int(proc["pid"]), force)
        except OSError as exc:
            display_message(self.window, TEXT["error"], str(exc))
        self.refresh_processes()

    def on_kill_all_processes(self, _button) -> None:
        processes = scan_processes(self.current_prefix())
        for proc in processes:
            try:
                kill_pid(int(proc["pid"]), True)
            except OSError:
                pass
        self.refresh_processes()
        self.set_status(f"{TEXT['kill_all']}: {len(processes)}")

    def browse_prefix(self, combo: Gtk.ComboBoxText) -> None:
        dialog = Gtk.FileChooserNative(
            title=TEXT["prefix"],
            transient_for=self.window,
            action=Gtk.FileChooserAction.SELECT_FOLDER,
            accept_label=TEXT["browse"],
            cancel_label=TEXT["cancel"],
        )
        dialog.connect("response", lambda d, response, selector=combo: self.on_prefix_response(d, response, selector))
        dialog.show()

    def on_prefix_response(self, dialog, response, combo: Gtk.ComboBoxText) -> None:
        if response == Gtk.ResponseType.ACCEPT:
            file = dialog.get_file()
            if file:
                path = Path(file.get_path())
                if str(path) not in [str(item) for item in self.prefixes]:
                    self.prefixes.append(path)
                    for selector in (self.apps_prefix_combo, self.process_prefix_combo):
                        if selector:
                            selector.append_text(str(path))
                combo.set_active(len(self.prefixes) - 1)
                self.refresh_all()
        dialog.destroy()


def main() -> int:
    warnings.filterwarnings("ignore", category=DeprecationWarning)
    app = ManagerApp()
    try:
        return app.run(sys.argv)
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
