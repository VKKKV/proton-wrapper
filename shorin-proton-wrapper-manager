    def combo_entry(self, values: list[str], current: str) -> Gtk.ComboBoxText:
        combo = Gtk.ComboBoxText.new_with_entry()
        seen = set()
        for value in values + ([current] if current else []):
            if not value or value in seen:
                continue
            seen.add(value)
            combo.append_text(value)
        child = combo.get_child()
        if isinstance(child, Gtk.Entry):
            child.set_text(current)
            child.set_hexpand(True)
        combo.set_hexpand(True)
        return combo

    def combo_entry_text(self, combo: Gtk.ComboBoxText) -> str:
        child = combo.get_child()
        if isinstance(child, Gtk.Entry):
            return child.get_text().strip()
        return combo.get_active_text() or ""

