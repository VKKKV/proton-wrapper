    def refresh_apps(self) -> None:
        self.clear_list(self.apps_list)
        prefix = self.page_prefix("apps")
        apps = scan_apps(prefix)
        if not apps:
            self.apps_list.append(self.empty_row(TEXT["no_apps"]))
            return
        for app in apps:
            row = Gtk.ListBoxRow()
            box = self.row_box()
            box.append(self.icon_widget(icon_for_app(prefix, app)))
            box.append(self.text_column(app_display_name(app), app["path"]))
            run = self.compact_button(TEXT["run"], "run-button")
            run.connect("clicked", lambda _b, item=app, item_prefix=prefix: self.run_path(item["path"], str(item_prefix), item.get("runner", "")))
            box.append(run)
            if app.get("kind") == "saved-config":
                config = self.compact_button(TEXT["reconfigure"])
                config.connect("clicked", lambda _b, item=app: self.edit_cache_entry(item))
                box.append(config)
            box.append(self.app_menu_button(app))
            row.set_child(box)
            self.apps_list.append(row)

    def refresh_processes(self) -> None:
        self.clear_list(self.process_list)
        processes = scan_processes(self.page_prefix("processes"))
        if not processes:
            self.process_list.append(self.empty_row(TEXT["no_processes"]))
            return
        for proc in processes:
            row = Gtk.ListBoxRow()
            box = self.row_box()
            title = f"{proc['name']}  PID {proc['pid']}  {proc['age']}"
            command = proc["command"]
            if len(command) > 120:
                command = command[:117] + "..."
            box.append(self.text_column(title, command))
            force = self.compact_button("", "menu-item-danger")
            force.add_css_class("icon-button")
            force.set_size_request(34, 34)
            force.set_valign(Gtk.Align.CENTER)
            force.set_tooltip_text(TEXT["force_kill"])
            force.add_css_class("destructive-action")
            force.connect("clicked", lambda _b, item=proc: self.kill_process(item, True))
            box.append(force)
            row.set_child(box)
            self.process_list.append(row)

    def set_status(self, message: str) -> None:
        if self.status_label:
            self.status_label.set_text(message)
        if self.status_clear_source_id:
            GLib.source_remove(self.status_clear_source_id)
        self.status_clear_source_id = GLib.timeout_add_seconds(4, self.clear_status)

    def clear_status(self) -> bool:
        if self.status_label:
            self.status_label.set_text("")
        self.status_clear_source_id = 0
        return False

    def run_path(self, path: str, prefix: str = "", runner: str = "") -> None:
        if not path:
            return
        command = [self.wrapper, "-p", prefix or str(self.current_prefix())]
        if runner:
            command.extend(["--runner", runner])
        command.append(path)
        subprocess.Popen(command)
        self.set_status(f"{TEXT['run']}: {path}")

    def reconfigure(self, exe: str) -> None:
        if not exe:
            return
        subprocess.Popen([self.configure, exe])

