def read_desktop_name(path: Path) -> str:
    if not path.is_file():
        return ""
    for line in path.read_text(errors="ignore").splitlines():
        if line.startswith("Name="):
            return line.split("=", 1)[1]
    return ""


def rewrite_desktop_name(path: Path, name: str) -> None:
    lines = []
    changed = False
    for line in path.read_text(errors="ignore").splitlines():
        if line.startswith("Name="):
            lines.append(f"Name={name}")
            changed = True
        else:
            lines.append(line)
    if not changed:
        lines.insert(2, f"Name={name}")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def maybe_update_desktop_database() -> None:
    if not shutil_which("update-desktop-database"):
        return
    subprocess.run(["update-desktop-database", str(data_home() / "applications")], check=False)


def shutil_which(name: str) -> str | None:
    for part in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(part) / name
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def process_start_time(pid: int) -> str:
    try:
        started = Path(f"/proc/{pid}").stat().st_ctime
    except OSError:
        return ""
    seconds = max(0, int(time.time() - started))
    if seconds < 60:
        return f"{seconds}s"
    if seconds < 3600:
        return f"{seconds // 60}m"
    return f"{seconds // 3600}h{seconds % 3600 // 60}m"


def scan_processes(prefix: Path) -> list[dict[str, str]]:
    prefix = expand_path(prefix)
    wineprefix = str(prefix / "pfx")
    steam_data = str(prefix)
    result = []
    for proc in Path("/proc").iterdir():
        if not proc.name.isdigit():
            continue
        pid = int(proc.name)
        if pid == os.getpid():
            continue
        try:
            environ = (proc / "environ").read_bytes().split(b"\0")
        except OSError:
            continue
        matched = False
        for item in environ:
            if item == f"WINEPREFIX={wineprefix}".encode() or item == f"STEAM_COMPAT_DATA_PATH={steam_data}".encode():
                matched = True
                break
        if not matched:
            continue
        try:
            command = (proc / "cmdline").read_bytes().replace(b"\0", b" ").decode(errors="replace").strip()
        except OSError:
            command = ""
        try:
            name = (proc / "comm").read_text(errors="replace").strip()
        except OSError:
            name = ""
        result.append({"pid": str(pid), "name": name, "command": command or name, "age": process_start_time(pid)})
    return sorted(result, key=lambda item: int(item["pid"]))


def kill_pid(pid: int, force: bool = False) -> None:
    os.kill(pid, signal.SIGKILL if force else signal.SIGTERM)


def collect_cache_entries() -> list[dict[str, str]]:
    entries = []
    for conf in sorted(association_dir().glob("*.conf"), key=lambda item: item.stat().st_mtime, reverse=True):
        data = read_key_values(conf)
        exe = data.get("exe", "")
        if not exe:
            continue
        if not expand_path(exe).exists():
            conf.unlink(missing_ok=True)
            continue
        data["file"] = str(conf)
        prefix = expand_path(data.get("prefix", Path.home() / ".proton"))
        data["name"] = data.get("name") or inferred_exe_name(expand_path(exe), prefix)
        data["source"] = data.get("source") or "configured"
        entries.append(data)
    return entries


def write_cache_entry(entry: dict[str, str]) -> None:
    path = Path(entry.get("file") or cache_file_for_path(entry.get("exe", "")))
    path.parent.mkdir(parents=True, exist_ok=True)
    old_path = Path(entry.get("file", "")) if entry.get("file") else None
    new_path = cache_file_for_path(entry.get("exe", ""))
    if new_path != path:
        path = new_path
    entry["file"] = str(path)
    keys = [
        "name", "exe", "prefix", "runner", "gamescope", "gamescope_fullscreen", "gamescope_res",
        "gamescope_fps", "gamescope_fsr", "gamescope_args", "mangohud", "env_vars", "source",
    ]
    path.write_text(
        "".join(f"{key}={quote(entry.get(key, '')) if key == 'env_vars' else entry.get(key, '')}\n" for key in keys),
        encoding="utf-8",
    )
    if old_path and old_path != path:
        old_path.unlink(missing_ok=True)


