    def runner_combo(self, runners: list[dict[str, str]], current: str) -> Gtk.ComboBoxText:
        combo = Gtk.ComboBoxText()
        active_id = None
        for index, runner in enumerate(runners):
            combo.append(str(index), runner_label(runner))
            if runner.get("path") == current:
                active_id = str(index)
        if current and active_id is None:
            combo.append("current", f"{Path(current).parent.name or Path(current).name} · custom")
            active_id = "current"
        combo.set_active_id(active_id or ("0" if runners else None))
        combo.set_hexpand(True)
        combo.runner_paths = {str(index): runner.get("path", "") for index, runner in enumerate(runners)}
        combo.runner_paths["current"] = current
        return combo

    def runner_combo_path(self, combo: Gtk.ComboBoxText) -> str:
        active_id = combo.get_active_id()
        return getattr(combo, "runner_paths", {}).get(active_id, "") if active_id is not None else ""

