    def current_prefix(self) -> Path:
        combo = self.current_prefix_combo()
        text = combo.get_active_text() if combo else ""
        return expand_path(text or Path.home() / ".proton")

    def page_prefix(self, page: str) -> Path:
        combo = self.process_prefix_combo if page == "processes" else self.apps_prefix_combo
        text = combo.get_active_text() if combo else ""
        return expand_path(text or Path.home() / ".proton")

    def current_prefix_combo(self) -> Gtk.ComboBoxText | None:
        visible = self.stack.get_visible_child_name() if self.stack else "apps"
        if visible == "processes":
            return self.process_prefix_combo
        return self.apps_prefix_combo

    def reload_prefixes(self) -> None:
        self.prefixes = collect_prefixes()
        for combo in (self.apps_prefix_combo, self.process_prefix_combo):
            if not combo:
                continue
            current = combo.get_active_text()
            combo.remove_all()
            active_index = 0
            for index, prefix in enumerate(self.prefixes):
                combo.append_text(str(prefix))
                if str(prefix) == current:
                    active_index = index
            combo.set_active(active_index)

    def refresh_all(self) -> None:
        if self.popover_open:
            return
        self.refresh_apps()
        self.refresh_processes()

    def auto_refresh(self) -> bool:
        if self.popover_open:
            return True
        visible = self.stack.get_visible_child_name() if self.stack else ""
        if visible == "processes":
            self.refresh_processes()
        return True

