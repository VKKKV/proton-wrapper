[Desktop Entry]
Type=Application
Name=Configure Windows Software
Name[zh_CN]=设置Windows软件运行环境
Comment=Configure the Proton runner and prefix for Windows executables
Exec=shorin-proton-wrapper-configure %f
Icon=shorin-proton
